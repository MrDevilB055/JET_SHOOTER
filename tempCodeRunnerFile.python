# =========================================================

bullet_img = pygame.image.load(
    'Assets/Map_Asset/bullet.png'
).convert_alpha()

bullet_img = pygame.transform.scale(
    bullet_img,
    (25,50)
)

# =========================================================
# SOUNDS
# =========================================================

bullet_sound = pygame.mixer.Sound(
    'Assets/Music/NormalShot.mp3'
)

hit_sound = pygame.mixer.Sound(
    'Assets/Music/mixkit-video-game-blood-pop-2361.wav'
)

bass_sound = pygame.mixer.Sound(
    'Assets/Music/brvhrtz-stab-f-01-brvhrtz-224599.mp3'
)

# =========================================================
# FONT
# =========================================================

score_font = pygame.font.Font(
    'C:/Users/thund/Desktop/PYTHON PYGAME PROJECTS/Assets/Fonts/splatink_2/Splatink_PERSONAL_USE_ONLY.otf',
    40
)

# =========================================================
# STARS
# =========================================================

stars = []

for i in range(250):
    stars.append([
        random.randint(0, WIDTH),
        random.randint(0, HEIGHT),
        random.randint(1,4)
    ])

# =========================================================
# PARTICLES
# =========================================================

particles = []

# =========================================================
# BULLETS
# =========================================================

bullets = []
enemy_bullets = []

# =========================================================
# SCORE
# =========================================================

score = 0
combo = 1
wave = 1

# =========================================================
# SCREEN SHAKE
# =========================================================

screen_shake = 0

# =========================================================
# PLAYER CLASS
# =========================================================

class Player:

    def __init__(self):

        self.x = WIDTH//2
        self.y = HEIGHT-250

        self.velx = 0
        self.vely = 0

        self.acc = 1.2
        self.friction = 0.92

        self.health = 100
        self.max_health = 100

        self.fire_delay = 8
        self.fire_timer = 0

        self.boosting = False

        self.image = player_img

        self.rect = self.image.get_rect(
            center=(self.x,self.y)
        )

    def movement(self):

        keys = pygame.key.get_pressed()

        self.boosting = False

        if keys[pygame.K_a]:
            self.velx -= self.acc

        if keys[pygame.K_d]:
            self.velx += self.acc

        if keys[pygame.K_w]:
            self.vely -= self.acc

        if keys[pygame.K_s]:
            self.vely += self.acc

        # BOOST MODE
        if keys[pygame.K_LSHIFT]:

            self.velx *= 1.03
            self.vely *= 1.03

            self.boosting = True

            global screen_shake
            screen_shake = 5

        self.velx *= self.friction
        self.vely *= self.friction

        self.x += self.velx
        self.y += self.vely

        # BOUNDARIES
        self.x = max(350, min(980, self.x))
        self.y = max(250, min(700, self.y))

        self.rect.center = (self.x,self.y)

    def shoot(self):

        keys = pygame.key.get_pressed()

        if self.fire_timer > 0:
            self.fire_timer -= 1

        if keys[pygame.K_SPACE] and self.fire_timer <= 0:

            bullets.append(
                Bullet(self.x - 25, self.y - 50)
            )

            bullets.append(
                Bullet(self.x + 25, self.y - 50)
            )

            bullet_sound.play()

            self.fire_timer = self.fire_delay

    def draw(self):

        if self.boosting:
            screen.blit(player_boost_img,self.rect)
        else:
            screen.blit(self.image,self.rect)

        # HEALTH BAR
        pygame.draw.rect(screen,RED,(50,50,350,30))
        pygame.draw.rect(
            screen,
            GREEN,
            (
                50,
                50,
                350*(self.health/self.max_health),
                30
            )
        )

# =========================================================
# BULLET CLASS
# =========================================================

class Bullet:

    def __init__(self,x,y):

        self.x = x
        self.y = y

        self.speed = 20

        self.rect = bullet_img.get_rect(
            center=(self.x,self.y)
        )

    def update(self):

        self.y -= self.speed

        self.rect.center = (self.x,self.y)

        screen.blit(bullet_img,self.rect)

# =========================================================
# ENEMY CLASS
# =========================================================

class Enemy:

    def __init__(self):

        self.x = random.randint(380,960)
        self.y = random.randint(-400,-100)

        self.health = 40 + wave*5

        self.speed = random.uniform(2,5)

        self.rect = enemy_img.get_rect(
            center=(self.x,self.y)
        )

    def update(self):

        dx = player.x - self.x
        dy = player.y - self.y

        dist = math.hypot(dx,dy)

        if dist != 0:
            dx /= dist
            dy /= dist

        self.x += dx*self.speed
        self.y += dy*self.speed

        self.rect.center = (self.x,self.y)

        screen.blit(enemy_img,self.rect)

        # COLLISION
        if self.rect.colliderect(player.rect):

            player.health -= 0.3

            global screen_shake
            screen_shake = 15

# =========================================================
# BOSS CLASS
# =========================================================

class Boss:

    def __init__(self):

        self.x = WIDTH//2
        self.y = -300

        self.health = 3000

        self.speed = 2

        self.direction = 1

        self.rect = boss_img.get_rect(
            center=(self.x,self.y)
        )

        self.shoot_timer = 0

    def update(self):

        if self.y < 250:
            self.y += 2

        self.x += self.direction * 5

        if self.x > 1000:
            self.direction = -1

        if self.x < 400:
            self.direction = 1

        self.rect.center = (self.x,self.y)

        screen.blit(boss_img,self.rect)

        # BOSS BULLETS
        self.shoot_timer += 1

        if self.shoot_timer > 20:

            for i in range(-3,4):

                enemy_bullets.append([
                    self.x,
                    self.y,
                    i
                ])

            self.shoot_timer = 0

boss = None

# =========================================================
# PARTICLE CLASS
# =========================================================

class Particle:

    def __init__(self,x,y,color):

        self.x = x
        self.y = y

        self.vx = random.uniform(-5,5)
        self.vy = random.uniform(-5,5)

        self.life = random.randint(20,50)

        self.color = color

        self.radius = random.randint(2,7)

    def update(self):

        self.x += self.vx
        self.y += self.vy

        self.life -= 1

        pygame.draw.circle(
            screen,
            self.color,
            (int(self.x),int(self.y)),
            self.radius
        )

# =========================================================
# CREATE PLAYER
# =========================================================

player = Player()

# =========================================================
# ENEMIES
# =========================================================

enemies = []

spawn_timer = 0

# =========================================================
# LOADING TIMER
# =========================================================

game_time = 0

# =========================================================
# MAIN LOOP
# =========================================================

while True:

    dt = clock.tick(60) / 1000
    game_time += dt

    # =====================================================
    # EVENTS
    # =====================================================

    for event in pygame.event.get():

        if event.type == pygame.QUIT:
            pygame.quit()
            exit()

    # =====================================================
    # LOADING SCREEN
    # =====================================================

    if game_time < 4:

        screen.blit(LoadingScreen,(0,0))

        loading_text = score_font.render(
            "LOADING GALAXY SYSTEMS...",
            True,
            WHITE
        )

        screen.blit(loading_text,(600,850))

        pygame.display.update()
        continue

    # =====================================================
    # SCREEN SHAKE
    # =====================================================

    shake_x = random.randint(-screen_shake,screen_shake)
    shake_y = random.randint(-screen_shake,screen_shake)

    if screen_shake > 0:
        screen_shake -= 1

    # =====================================================
    # BACKGROUND
    # =====================================================

    screen.blit(room,(shake_x,shake_y))

    screen.blit(
        milky_way_map,
        (300+shake_x,200+shake_y)
    )

    # =====================================================
    # STARS
    # =====================================================

    for star in stars:

        star[1] += star[2]

        if star[1] > HEIGHT:
            star[0] = random.randint(0,WIDTH)
            star[1] = 0

        pygame.draw.circle(
            screen,
            WHITE,
            (
                star[0]+shake_x,
                star[1]+shake_y
            ),
            star[2]
        )

    # =====================================================
    # PLAYER
    # =====================================================

    player.movement()
    player.shoot()
    player.draw()

    # =====================================================
    # BULLETS
    # =====================================================

    for bullet in bullets[:]:

        bullet.update()

        if bullet.y < -100:
            bullets.remove(bullet)

    # =====================================================
    # SPAWN ENEMIES
    # =====================================================

    spawn_timer += 1

    if spawn_timer > max(20,80-wave*2):

        enemies.append(Enemy())

        spawn_timer = 0

    # =====================================================
    # ENEMIES
    # =====================================================

    for enemy in enemies[:]:

        enemy.update()

        for bullet in bullets[:]:

            if enemy.rect.colliderect(bullet.rect):

                enemy.health -= 20

                hit_sound.play()

                if bullet in bullets:
                    bullets.remove(bullet)

                for i in range(10):

                    particles.append(
                        Particle(
                            enemy.x,
                            enemy.y,
                            RED
                        )
                    )

                if enemy.health <= 0:

                    score += 100 * combo
                    combo += 1

                    screen_shake = 20

                    for i in range(40):

                        particles.append(
                            Particle(
                                enemy.x,
                                enemy.y,
                                YELLOW
                            )
                        )

                    enemies.remove(enemy)

                    break

    # =====================================================
    # BOSS SPAWN
    # =====================================================

    if score >= 5000 and boss is None:

        boss = Boss()

        bass_sound.play()

    # =====================================================
    # BOSS UPDATE
    # =====================================================

    if boss:

        boss.update()

        # BOSS COLLISION

        for bullet in bullets[:]:

            if boss.rect.colliderect(bullet.rect):

                boss.health -= 10

                if bullet in bullets:
                    bullets.remove(bullet)

                for i in range(6):

                    particles.append(
                        Particle(
                            bullet.x,
                            bullet.y,
                            PURPLE
                        )
                    )

        # BOSS HEALTH BAR

        pygame.draw.rect(
            screen,
            RED,
            (500,30,900,40)
        )

        pygame.draw.rect(
            screen,
            GREEN,
            (
                500,
                30,
                900*(boss.health/3000),
                40
            )
        )

        if boss.health <= 0:

            score += 10000
            boss = None

    # =====================================================
    # ENEMY BULLETS
    # =====================================================

    for bullet in enemy_bullets[:]:

        bullet[1] += 10
        bullet[0] += bullet[2]

        pygame.draw.circle(
            screen,
            BLUE,
            (int(bullet[0]),int(bullet[1])),
            12
        )

        bullet_rect = pygame.Rect(
            bullet[0],
            bullet[1],
            15,
            15
        )

        if bullet_rect.colliderect(player.rect):

            player.health -= 5

            combo = 1

            screen_shake = 25

            enemy_bullets.remove(bullet)

        if bullet[1] > HEIGHT:
            enemy_bullets.remove(bullet)

    # =====================================================
    # PARTICLES
    # =====================================================

    for particle in particles[:]:

        particle.update()

        if particle.life <= 0:
            particles.remove(particle)

    # =====================================================
    # UI
    # =====================================================

    score_text = score_font.render(
        f"SCORE : {score}",
        True,
        WHITE
    )

    combo_text = score_font.render(
        f"COMBO : x{combo}",
        True,
        YELLOW
    )

    wave = score // 2000 + 1

    wave_text = score_font.render(
        f"WAVE : {wave}",
        True,
        BLUE
    )

    screen.blit(score_text,(1450,40))
    screen.blit(combo_text,(1450,90))
    screen.blit(wave_text,(1450,140))

    # =====================================================
    # GAME OVER
    # =====================================================

    if player.health <= 0:

        game_over = pygame.font.SysFont(
            "Arial",
            120
        ).render(
            "GAME OVER",
            True,
            RED
        )

        screen.blit(
            game_over,
            (600,400)
        )

        pygame.display.update()

        pygame.time.delay(5000)

        pygame.quit()
        exit()

    pygame.display.update()