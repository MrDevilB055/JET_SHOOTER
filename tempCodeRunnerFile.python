).convert_alpha()

player_boost_img = pygame.transform.scale(
    player_boost_img,
    (170,170)
)

# =========================================================
# ENEMY ASSETS
# =========================================================

enemy_img = pygame.image.load(
    'C:/Users/thund/Desktop/PYTHON PYGAME PROJECTS/Assets/Map_Asset/enemysoldier.png'
).convert_alpha()

enemy_img = pygame.transform.scale(
    enemy_img,
    (80,80)
)

boss_img = pygame.image.load(
    'Assets/Map_Asset/final_boss.png'
).convert_alpha()

boss_img = pygame.transform.scale(
    boss_img,
    (300,300)
)

